# =============================================================================
# Turnkey Self-Hosted Business Server v1 — .env.template
# -----------------------------------------------------------------------------
# This is the ONLY file a deployer should edit per client. All Docker Compose
# services, Caddy routes, and scripts read values from here.
#
# Workflow:
#   1. cp .env.template .env
#   2. chmod 600 .env
#   3. Fill in CLIENT IDENTITY + SMTP + BACKUP values.
#   4. Generate all secrets (or run `scripts/deploy.sh` to auto-generate).
#
# Secret generation helpers (Linux):
#   Password (URL-safe, 32 chars): openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
#   Hex token (64 chars):          openssl rand -hex 32
#   UUID:                          cat /proc/sys/kernel/random/uuid
#
# Rules:
#   - Never commit a filled .env to git.
#   - Never reuse secrets across clients.
#   - .env must be chmod 600, owned by stackuser:stackuser.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# CLIENT IDENTITY
# ─────────────────────────────────────────────────────────────────────────────

# Human-readable client/company name. Appears in app titles and email footers.
# Required. Example: "Acme Corp"
CLIENT_NAME=

# Base domain for all services. Every service is exposed as <sub>.DOMAIN.
# For a lab/offline deploy, use "company.localhost" — Caddy will issue an
# internal self-signed cert. For production, use a real domain you control
# with wildcard A-record pointing at SERVER_IP.
# Required. Example: company.com  |  company.localhost
DOMAIN=company.localhost

# LAN IP of the Ubuntu VM hosting the stack. Used by Caddy's VPN-only matcher
# and as the default WireGuard endpoint when no public domain is set.
# Required. Example: 192.168.1.10
SERVER_IP=192.168.1.10

# IANA timezone. Applied to every container for consistent timestamps & cron.
# Required. Example: America/New_York, Europe/Berlin, UTC
# Full list: timedatectl list-timezones
TIMEZONE=UTC

# Admin contact. Used by Caddy (Let's Encrypt account) and app notifications.
# Required. Example: support@yourmsp.com
ADMIN_EMAIL=


# ─────────────────────────────────────────────────────────────────────────────
# NETWORK / ACCESS POLICY
# ─────────────────────────────────────────────────────────────────────────────

# CIDR block that counts as "trusted" for VPN-only services (crm, vpn, status).
# This is the WireGuard tunnel subnet handed out by wg-easy PLUS the LAN.
# Required. Default covers the wg-easy default and a typical /24 LAN.
TRUSTED_CIDRS=10.8.0.0/24 192.168.0.0/16


# ─────────────────────────────────────────────────────────────────────────────
# PASSWORDS & SECRETS
# Generate every value below. deploy.sh will auto-fill blanks with
# `openssl rand` output if you prefer a hands-off install.
# ─────────────────────────────────────────────────────────────────────────────

# --- Nextcloud ---------------------------------------------------------------

# PostgreSQL password for the Nextcloud DB user.
# Required. Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
NC_DB_PASS=

# Username for the Nextcloud admin account created on first run.
# Required. Use an email-style local-part for SSO compatibility later.
# Example: admin
NC_ADMIN_USER=admin

# Password for the Nextcloud admin account.
# Required. Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
NC_ADMIN_PASS=


# --- ONLYOFFICE --------------------------------------------------------------

# Shared JWT secret between Nextcloud and ONLYOFFICE Document Server.
# MUST be identical on both sides or document editing will fail.
# Required. Generate: openssl rand -hex 32
ONLYOFFICE_JWT=


# --- Dolibarr ----------------------------------------------------------------

# MariaDB password for the Dolibarr DB user.
# Required. Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
DOLI_DB_PASS=

# Dolibarr super-admin password (user: "admin" — fixed by Dolibarr installer).
# Required. Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
DOLI_ADMIN_PASS=


# --- Kimai -------------------------------------------------------------------

# MariaDB password for the Kimai DB user.
# Required. Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
KIMAI_DB_PASS=

# Email address for the initial Kimai super-admin.
# Required. Should be the business owner or primary admin.
KIMAI_ADMIN_EMAIL=

# Password for the initial Kimai super-admin.
# Required. Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
KIMAI_ADMIN_PASS=


# --- Paperless-ngx -----------------------------------------------------------

# PostgreSQL password for the Paperless DB user.
# Required. Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
PAPERLESS_DB_PASS=

# Django SECRET_KEY for Paperless. Rotating this invalidates all sessions.
# Required. Generate: openssl rand -hex 32
PAPERLESS_SECRET=

# Paperless superuser username (created on first run).
# Required. Example: admin
PAPERLESS_ADMIN_USER=admin

# Paperless superuser password.
# Required. Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
PAPERLESS_ADMIN_PASS=


# --- DocuSeal ----------------------------------------------------------------

# DocuSeal Rails SECRET_KEY_BASE. Rotating invalidates signed URLs / sessions.
# Required. Generate: openssl rand -hex 64
DOCUSEAL_SECRET=


# --- Vaultwarden -------------------------------------------------------------

# Admin token for the Vaultwarden /admin panel. Keep this offline — anyone
# with it can reset master passwords.
# Required. Generate: openssl rand -base64 48
VAULTWARDEN_ADMIN=


# --- WireGuard (wg-easy) -----------------------------------------------------

# Password for the wg-easy web UI (at vpn.DOMAIN, VPN-only).
# Required. Generate: openssl rand -base64 24
WG_PASSWORD=

# Public host clients use in their WireGuard config Endpoint line.
# For lab: use SERVER_IP. For production: use vpn.DOMAIN with a public A-record.
# Required. Example: vpn.company.com  |  192.168.1.10
WG_HOST=192.168.1.10

# UDP port for WireGuard. Must be forwarded on the router if remote access
# from outside the LAN is required.
# Required. Default: 51820
WG_PORT=51820


# ─────────────────────────────────────────────────────────────────────────────
# BACKUP CONFIGURATION (Restic + Ofelia)
# ─────────────────────────────────────────────────────────────────────────────

# Restic repository URI.
#   Local disk:  /srv/backups
#   S3:          s3:s3.amazonaws.com/<bucket>
#   B2:          b2:<bucket>:/path
#   SFTP:        sftp:user@host:/path
# Required. Example: s3:s3.amazonaws.com/acme-backups
RESTIC_REPOSITORY=/srv/backups

# Encryption password for the Restic repo. Losing this = losing all backups.
# Store a copy in Vaultwarden AND offline (printed, sealed).
# Required. Generate: openssl rand -base64 48
RESTIC_PASSWORD=

# S3/B2 credentials. Leave BLANK for local / SFTP repos.
# Optional. Fill only if RESTIC_REPOSITORY is s3: or b2:.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Ofelia cron expression (standard 5-field cron) for nightly backup runs.
# Required. Default: daily at 02:00 server-local time.
BACKUP_SCHEDULE=0 2 * * *


# ─────────────────────────────────────────────────────────────────────────────
# SMTP (for app email notifications — password resets, invoice delivery, etc.)
# Leave all fields blank to disable email. Apps will still function.
# ─────────────────────────────────────────────────────────────────────────────

# SMTP relay hostname.
# Optional. Example: smtp.sendgrid.net, smtp.mailgun.org, smtp.gmail.com
SMTP_HOST=

# SMTP port. 587 = STARTTLS (preferred), 465 = implicit TLS, 25 = plain.
# Optional. Default: 587
SMTP_PORT=587

# SMTP username (often the full email address or an API key ID).
# Optional. Example: apikey, noreply@company.com
SMTP_USER=

# SMTP password or API key secret.
# Optional. Treat as a secret — store a copy in Vaultwarden.
SMTP_PASS=

# From-address shown in outbound mail. Must be authorized on the SMTP relay.
# Optional. Example: "Acme Corp <noreply@company.com>"
SMTP_FROM=
